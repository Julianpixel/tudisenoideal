---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { db, DonationInfo, eq } from 'astro:db';

let successMsg = '';
let errorMsg = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action') as string;

  if (action === 'delete') {
    const id = parseInt(form.get('id') as string, 10);
    await db.delete(DonationInfo).where(eq(DonationInfo.id, id));
    successMsg = '✓ Eliminado.';
  } else if (action === 'save') {
    const idStr = form.get('id') as string;
    const id = idStr && idStr.trim() !== '' ? parseInt(idStr, 10) : null;
    
    const payload = {
      personName:    (form.get('personName')    as string).trim(),
      bankName:      (form.get('bankName')      as string).trim(),
      accountHolder: (form.get('accountHolder') as string).trim(),
      accountNumber: (form.get('accountNumber') as string).trim(),
      accountType:   (form.get('accountType')   as string).trim() || 'Cuenta Corriente',
      transferAlias: (form.get('transferAlias') as string)?.trim() || null,
      order:         parseInt(form.get('order') as string || '0', 10),
      isActive:      true,
    };
    if (id) {
      await db.update(DonationInfo).set(payload).where(eq(DonationInfo.id, id));
    } else {
      await db.insert(DonationInfo).values(payload);
    }
    successMsg = '✓ Guardado correctamente.';
  }
}

const donations = await db.select().from(DonationInfo);
donations.sort((a, b) => a.order - b.order);
import Sidebar from '../../components/admin/Sidebar.astro';
---
<Layout>
  <div class="admin-shell">
    <Sidebar currentPath="/admin/donaciones" />

    <main class="admin-main">
      <header class="admin-header">
        <div>
          <p class="header-eyebrow">Panel de Administración</p>
          <h1 class="header-title">Gestión de Donaciones</h1>
        </div>
        <a href="/donaciones" class="btn btn-forest btn-sm" target="_blank">Ver Página →</a>
      </header>

      {successMsg && <div class="alert alert-success">{successMsg}</div>}
      {errorMsg   && <div class="alert alert-error">{errorMsg}</div>}

      <!-- New / Edit Form -->
      <div class="form-card">
        <h3 class="card-title">➕ Agregar / Editar Cuenta</h3>
        <form method="POST" id="donation-form" class="edit-form">
          <input type="hidden" name="_action" value="save" />
          <input type="hidden" name="id" id="edit-id" value="" />

          <div class="form-grid">
            <div class="form-group">
              <label for="personName">Etiqueta (ej: El Novio)</label>
              <input type="text" id="personName" name="personName" required placeholder="La Novia" />
            </div>
            <div class="form-group">
              <label for="bankName">Banco</label>
              <input type="text" id="bankName" name="bankName" required placeholder="Banco Nacional" />
            </div>
            <div class="form-group">
              <label for="accountHolder">Titular de la cuenta</label>
              <input type="text" id="accountHolder" name="accountHolder" required placeholder="Juan Pérez" />
            </div>
            <div class="form-group">
              <label for="accountNumber">Número de cuenta</label>
              <input type="text" id="accountNumber" name="accountNumber" required placeholder="0123-4567-8901" />
            </div>
            <div class="form-group">
              <label for="accountType">Tipo de cuenta</label>
              <input type="text" id="accountType" name="accountType" placeholder="Cuenta de Ahorros" />
            </div>
            <div class="form-group">
              <label for="transferAlias">Alias / Zelle / PayPal (opcional)</label>
              <input type="text" id="transferAlias" name="transferAlias" placeholder="ejemplo@zelle.com" />
            </div>
            <div class="form-group">
              <label for="order">Orden de aparición</label>
              <input type="number" id="order" name="order" value="0" min="0" />
            </div>
          </div>
          <div class="form-actions">
            <button type="submit" class="btn btn-forest">Guardar</button>
            <button type="button" id="clear-btn" class="btn btn-outline">Limpiar</button>
          </div>
        </form>
      </div>

      <!-- Existing entries -->
      <div class="list-card">
        <h3 class="card-title">💳 Cuentas Registradas</h3>
        {donations.length === 0 && <p class="empty">No hay cuentas registradas.</p>}
        <div class="donations-list">
          {donations.map(d => (
            <div class="donation-row">
              <div class="donation-info">
                <p class="donation-label">{d.personName}</p>
                <p class="donation-meta">{d.bankName} · {d.accountHolder} · {d.accountNumber}</p>
                {d.transferAlias && <p class="donation-alias">{d.transferAlias}</p>}
              </div>
              <div class="row-actions">
                <button
                  type="button"
                  class="btn-edit"
                  data-id={d.id}
                  data-personname={d.personName}
                  data-bankname={d.bankName}
                  data-accountholder={d.accountHolder}
                  data-accountnumber={d.accountNumber}
                  data-accounttype={d.accountType}
                  data-transferalias={d.transferAlias || ''}
                  data-order={d.order}
                >
                  ✏️ Editar
                </button>
                <form method="POST" style="display:inline" class="form-delete">
                  <input type="hidden" name="_action" value="delete" />
                  <input type="hidden" name="id" value={d.id} />
                  <button type="submit" class="btn-delete">🗑</button>
                </form>
              </div>
            </div>
          ))}
        </div>
      </div>
    </main>
  </div>
</Layout>

<script>
  document.querySelectorAll('.btn-edit').forEach(button => {
    button.addEventListener('click', (e) => {
      const btn = e.currentTarget as HTMLElement;
      (document.getElementById('edit-id') as HTMLInputElement).value = btn.dataset.id || '';
      (document.getElementById('personName') as HTMLInputElement).value = btn.dataset.personname || '';
      (document.getElementById('bankName') as HTMLInputElement).value = btn.dataset.bankname || '';
      (document.getElementById('accountHolder') as HTMLInputElement).value = btn.dataset.accountholder || '';
      (document.getElementById('accountNumber') as HTMLInputElement).value = btn.dataset.accountnumber || '';
      (document.getElementById('accountType') as HTMLInputElement).value = btn.dataset.accounttype || '';
      (document.getElementById('transferAlias') as HTMLInputElement).value = btn.dataset.transferalias || '';
      (document.getElementById('order') as HTMLInputElement).value = btn.dataset.order || '0';
      document.getElementById('donation-form')?.scrollIntoView({ behavior: 'smooth' });
    });
  });

  document.querySelectorAll('.form-delete').forEach(form => {
    form.addEventListener('submit', (e) => {
      if (!confirm('¿Seguro que deseas eliminar esta cuenta?')) {
        e.preventDefault();
      }
    });
  });

  document.getElementById('clear-btn')?.addEventListener('click', () => {
    (document.getElementById('edit-id') as HTMLInputElement).value = '';
    (document.getElementById('donation-form') as HTMLFormElement).reset();
  });
</script>

<style>
  .admin-shell { display: flex; min-height: 100vh; background: #f4f5f7; font-family: 'Montserrat', sans-serif; }
  .admin-main { flex: 1; padding: 2.5rem 2rem; overflow-y: auto; max-width: 860px; }
  .admin-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem; }
  .header-eyebrow { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-gold); margin: 0 0 0.25rem; }
  .header-title { font-family: 'Cormorant Garamond', serif; font-size: 2.2rem; font-weight: 400; color: var(--color-forest); margin: 0; }
  .alert { padding: 0.85rem 1.25rem; border-radius: 10px; font-size: 0.85rem; font-weight: 500; margin-bottom: 1.5rem; }
  .alert-success { background: #e6f6ec; color: #1e8449; border: 1px solid #a9dfbf; }
  .alert-error   { background: #fdecea; color: #c0392b; border: 1px solid #f1b4b0; }
  .form-card, .list-card { background: #fff; border-radius: 14px; padding: 2rem; box-shadow: 0 2px 12px rgba(44,74,62,0.06); margin-bottom: 1.5rem; }
  .card-title { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; color: var(--color-forest); margin: 0 0 1.5rem; border-bottom: 1px solid #f0f0f0; padding-bottom: 0.75rem; }
  .edit-form { display: flex; flex-direction: column; gap: 1rem; }
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  @media (max-width: 600px) { .form-grid { grid-template-columns: 1fr; } }
  .form-group { display: flex; flex-direction: column; gap: 0.35rem; }
  label { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #555; }
  input[type="text"], input[type="number"] { padding: 0.8rem 1rem; border: 1.5px solid #e0e0e0; border-radius: 10px; font-family: 'Montserrat', sans-serif; font-size: 0.9rem; width: 100%; box-sizing: border-box; }
  input:focus { outline: none; border-color: var(--color-gold); }
  .form-actions { display: flex; gap: 0.75rem; }
  .btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.8rem 2rem; font-size: 0.8rem; font-family: 'Montserrat', sans-serif; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; border-radius: 50px; cursor: pointer; border: 2px solid; transition: all 0.25s; text-decoration: none; align-self: flex-start; }
  .btn-forest { background: var(--color-forest); color: white; border-color: var(--color-forest); }
  .btn-forest:hover { background: transparent; color: var(--color-forest); }
  .btn-outline { background: transparent; color: var(--color-forest); border-color: var(--color-forest); }
  .btn-outline:hover { background: var(--color-forest); color: white; }
  .btn-sm { padding: 0.55rem 1.1rem; font-size: 0.72rem; }
  .empty { color: #999; font-style: italic; }
  .donations-list { display: flex; flex-direction: column; gap: 0.75rem; }
  .donation-row { display: flex; justify-content: space-between; align-items: center; padding: 1rem 1.25rem; border: 1px solid #f0f0f0; border-radius: 12px; gap: 1rem; flex-wrap: wrap; }
  .donation-label { font-weight: 600; color: var(--color-forest); margin: 0 0 0.2rem; }
  .donation-meta { font-size: 0.82rem; color: #666; margin: 0; }
  .donation-alias { font-size: 0.78rem; color: var(--color-gold); margin: 0.2rem 0 0; }
  .row-actions { display: flex; gap: 0.5rem; align-items: center; flex-shrink: 0; }
  .btn-edit { background: none; border: 1px solid #e0e0e0; border-radius: 6px; cursor: pointer; padding: 0.35rem 0.75rem; font-size: 0.78rem; font-family: 'Montserrat', sans-serif; transition: background 0.2s; }
  .btn-edit:hover { background: #f4f5f7; }
  .btn-delete { background: none; border: 1px solid #f1b4b0; border-radius: 6px; color: #c0392b; cursor: pointer; padding: 0.35rem 0.6rem; font-size: 0.85rem; transition: background 0.2s; }
  .btn-delete:hover { background: #fdecea; }
</style>
