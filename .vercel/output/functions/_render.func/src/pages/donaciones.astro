---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import { db, DonationInfo } from 'astro:db';

const donations = await db.select().from(DonationInfo);
donations.sort((a, b) => a.order - b.order).filter(d => d.isActive);
---
<Layout>
<div class="donaciones-page">
  <div class="page-header">
    <a href="/" class="back-link">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      Volver al inicio
    </a>

    <p class="eyebrow">Celebra con nosotros</p>
    <h1 class="page-title">Lluvia de Sobres</h1>
    <div class="section-ornament"><span>❧</span></div>
    <p class="page-subtitle">
      Tu presencia es el regalo más grande que nos puedes dar.<br/>
      Sin embargo, si deseas hacernos un regalo especial, te dejamos nuestros datos.<br/>
      <em>¡Gracias desde el fondo de nuestros corazones!</em> 💛
    </p>
  </div>

  {donations.length === 0 && (
    <div class="empty">Los datos bancarios estarán disponibles próximamente.</div>
  )}

  <div class="cards-grid">
    {donations.map(d => (
      <div class="donation-card">
        <div class="card-top">
          <div class="card-avatar">{d.personName.charAt(0)}</div>
          <div>
            <p class="card-person">{d.personName}</p>
            <p class="card-bank">{d.bankName}</p>
          </div>
        </div>

        <div class="card-divider"></div>

        <dl class="card-details">
          <div class="detail-row">
            <dt>Titular</dt>
            <dd>{d.accountHolder}</dd>
          </div>
          <div class="detail-row">
            <dt>Número de cuenta</dt>
            <dd class="copyable" data-copy={d.accountNumber}>{d.accountNumber} <button class="copy-btn" title="Copiar">📋</button></dd>
          </div>
          <div class="detail-row">
            <dt>Tipo</dt>
            <dd>{d.accountType}</dd>
          </div>
          {d.transferAlias && (
            <div class="detail-row">
              <dt>Transferencia / Alias</dt>
              <dd class="copyable" data-copy={d.transferAlias}>{d.transferAlias} <button class="copy-btn" title="Copiar">📋</button></dd>
            </div>
          )}
        </dl>
      </div>
    ))}
  </div>

  <p class="note">
    🙏 Cada contribución será usado para comenzar nuestra nueva vida juntos.
  </p>
</div>
</Layout>

<script>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const text = (btn.parentElement as HTMLElement)?.dataset.copy || '';
      navigator.clipboard.writeText(text);
      const orig = btn.textContent;
      btn.textContent = '✓';
      setTimeout(() => btn.textContent = orig, 1800);
    });
  });
</script>

<style>
  .donaciones-page { min-height: 100vh; background: var(--color-ivory); padding: 4rem 1.5rem 6rem; }
  .page-header { max-width: 680px; margin: 0 auto 4rem; text-align: center; }
  .back-link { display: inline-flex; align-items: center; gap: 0.5rem; font-family: 'Montserrat', sans-serif; font-size: 0.8rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-text-muted); text-decoration: none; margin-bottom: 2.5rem; transition: color 0.25s; }
  .back-link:hover { color: var(--color-forest); }
  .back-link svg { width: 16px; height: 16px; }
  .eyebrow { font-family: 'Montserrat', sans-serif; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.35em; text-transform: uppercase; color: var(--color-gold); margin: 0 0 0.75rem; }
  .page-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.4rem, 6vw, 4rem); font-weight: 400; color: var(--color-forest); margin: 0 0 0.5rem; }
  .page-subtitle { font-size: 0.95rem; color: var(--color-text-muted); line-height: 1.8; margin: 0.5rem 0 0; }
  .page-subtitle em { color: var(--color-gold); font-style: normal; }
  .empty { text-align: center; padding: 3rem; color: #999; font-style: italic; }
  .note { text-align: center; font-size: 0.9rem; color: var(--color-text-muted); margin-top: 3rem; }

  .cards-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 2rem; max-width: 900px; margin: 0 auto; }

  .donation-card { background: #fff; border-radius: 24px; padding: 2.5rem; box-shadow: 0 8px 32px rgba(44,74,62,0.1); border-top: 4px solid var(--color-gold); transition: transform 0.3s, box-shadow 0.3s; }
  .donation-card:hover { transform: translateY(-4px); box-shadow: 0 16px 48px rgba(44,74,62,0.15); }

  .card-top { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem; }
  .card-avatar { width: 52px; height: 52px; border-radius: 50%; background: linear-gradient(135deg, var(--color-forest), var(--color-forest-mid)); display: flex; align-items: center; justify-content: center; font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; color: var(--color-gold-light); flex-shrink: 0; }
  .card-person { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; color: var(--color-forest); margin: 0 0 0.15rem; font-weight: 400; }
  .card-bank { font-family: 'Montserrat', sans-serif; font-size: 0.78rem; font-weight: 500; color: var(--color-text-muted); margin: 0; }
  .card-divider { height: 1px; background: linear-gradient(90deg, transparent, rgba(201,169,110,0.4), transparent); margin-bottom: 1.5rem; }

  .card-details { margin: 0; display: flex; flex-direction: column; gap: 0.85rem; }
  .detail-row { display: flex; flex-direction: column; gap: 0.2rem; }
  dt { font-family: 'Montserrat', sans-serif; font-size: 0.68rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-text-muted); }
  dd { font-family: 'Montserrat', sans-serif; font-size: 0.92rem; color: var(--color-text); margin: 0; display: flex; align-items: center; gap: 0.5rem; }

  .copy-btn { background: none; border: none; cursor: pointer; font-size: 0.85rem; padding: 0.1rem 0.3rem; border-radius: 4px; transition: background 0.2s; }
  .copy-btn:hover { background: #f0f0f0; }
</style>
