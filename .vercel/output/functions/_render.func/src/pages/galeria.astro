---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import { db, GalleryImage } from 'astro:db';

const images = await db.select().from(GalleryImage);
images.sort((a, b) => a.order - b.order);
---
<Layout>
<div class="galeria-page">
  <div class="galeria-header">
    <a href="/" class="back-link">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      Volver al inicio
    </a>
    <p class="section-label">Momentos</p>
    <h1 class="page-title">Nuestra Historia Completa</h1>
    <div class="section-ornament"><span>❧</span></div>
    <p class="page-subtitle">Cada imagen es un capítulo de nuestra historia de amor.</p>
  </div>

  {images.length === 0 && (
    <div class="empty">No hay imágenes en la galería todavía.</div>
  )}

  <div class="gallery-grid" id="gallery-grid">
    {images.map((img, i) => (
      <div
        class="gallery-item"
        style={`animation-delay: ${i * 0.08}s`}
        data-src={img.url}
        data-caption={img.caption || ''}
        role="button"
        tabindex="0"
        aria-label={img.caption || 'Ver foto'}
      >
        <img src={img.url} alt={img.caption || 'Galería de boda'} loading="lazy" />
        {img.caption && (
          <div class="item-overlay">
            <p class="item-caption">{img.caption}</p>
          </div>
        )}
      </div>
    ))}
  </div>
</div>

<!-- Lightbox -->
<div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-hidden="true">
  <button class="lb-close" id="lb-close" aria-label="Cerrar">&times;</button>
  <button class="lb-prev" id="lb-prev" aria-label="Anterior">&#8249;</button>
  <button class="lb-next" id="lb-next" aria-label="Siguiente">&#8250;</button>
  <div class="lb-content">
    <img id="lb-img" src="" alt="" />
    <p id="lb-caption" class="lb-caption"></p>
  </div>
</div>
</Layout>

<script>
  const items = Array.from(document.querySelectorAll('.gallery-item')) as HTMLElement[];
  const lightbox = document.getElementById('lightbox')!;
  const lbImg = document.getElementById('lb-img') as HTMLImageElement;
  const lbCaption = document.getElementById('lb-caption')!;
  let currentIndex = 0;
  function openLightbox(index: number) {
    currentIndex = index;
    const item = items[index];
    lbImg.src = item.dataset.src!;
    lbCaption.textContent = item.dataset.caption || '';
    lightbox.classList.add('active');
    lightbox.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    lbImg.classList.remove('loaded');
    lbImg.onload = () => lbImg.classList.add('loaded');
  }
  function closeLightbox() {
    lightbox.classList.remove('active');
    lightbox.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }
  items.forEach((item, i) => {
    item.addEventListener('click', () => openLightbox(i));
    item.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openLightbox(i); } });
  });
  document.getElementById('lb-close')!.addEventListener('click', closeLightbox);
  document.getElementById('lb-prev')!.addEventListener('click', () => openLightbox((currentIndex - 1 + items.length) % items.length));
  document.getElementById('lb-next')!.addEventListener('click', () => openLightbox((currentIndex + 1) % items.length));
  lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('active')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') openLightbox((currentIndex - 1 + items.length) % items.length);
    if (e.key === 'ArrowRight') openLightbox((currentIndex + 1) % items.length);
  });

  // Animate on scroll
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) (e.target as HTMLElement).style.animationPlayState = 'running'; });
  }, { threshold: 0.05 });
  document.querySelectorAll('.gallery-item').forEach((el: Element) => { (el as HTMLElement).style.animationPlayState = 'paused'; observer.observe(el); });
</script>

<style>
  .galeria-page { min-height: 100vh; background: var(--color-ivory); padding: 4rem 1.5rem 6rem; }
  .galeria-header { max-width: 700px; margin: 0 auto 4rem; text-align: center; }
  .back-link { display: inline-flex; align-items: center; gap: 0.5rem; font-family: 'Montserrat', sans-serif; font-size: 0.8rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-text-muted); text-decoration: none; margin-bottom: 2.5rem; transition: color 0.25s; }
  .back-link:hover { color: var(--color-forest); }
  .back-link svg { width: 16px; height: 16px; }
  .section-label { font-family: 'Montserrat', sans-serif; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.35em; text-transform: uppercase; color: var(--color-gold); margin: 0 0 0.75rem; }
  .page-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.4rem, 5vw, 3.8rem); font-weight: 400; color: var(--color-forest); margin: 0 0 0.5rem; }
  .page-subtitle { font-size: 0.9rem; color: var(--color-text-muted); margin: 0.5rem 0 0; }
  .empty { text-align: center; color: #999; font-style: italic; padding: 4rem; }
  .gallery-grid { columns: 4; column-gap: 1rem; max-width: 1300px; margin: 0 auto; }
  @media (max-width: 1024px) { .gallery-grid { columns: 3; } }
  @media (max-width: 768px)  { .gallery-grid { columns: 2; } }
  @media (max-width: 480px)  { .gallery-grid { columns: 1; } }
  .gallery-item { break-inside: avoid; margin-bottom: 1rem; position: relative; overflow: hidden; border-radius: 14px; cursor: pointer; opacity: 0; animation: fadeInUp 0.5s ease forwards; }
  @keyframes fadeInUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
  .gallery-item img { width: 100%; display: block; border-radius: 14px; transition: transform 0.45s ease; }
  .gallery-item:hover img { transform: scale(1.04); }
  .item-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(44,74,62,0.85), transparent 60%); border-radius: 14px; opacity: 0; transition: opacity 0.3s; display: flex; align-items: flex-end; padding: 1rem; }
  .gallery-item:hover .item-overlay { opacity: 1; }
  .item-caption { font-family: 'Cormorant Garamond', serif; font-size: 1rem; color: #fff; margin: 0; font-style: italic; }
  .lightbox { position: fixed; inset: 0; background: rgba(10,20,15,0.95); z-index: 9999; display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity 0.35s ease; }
  .lightbox.active { opacity: 1; pointer-events: all; }
  .lb-content { max-width: 90vw; max-height: 90vh; display: flex; flex-direction: column; align-items: center; gap: 1rem; }
  #lb-img { max-width: 90vw; max-height: 80vh; border-radius: 12px; object-fit: contain; opacity: 0; transition: opacity 0.3s ease; }
  #lb-img.loaded { opacity: 1; }
  .lb-caption { font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; color: rgba(255,255,255,0.7); margin: 0; font-style: italic; }
  .lb-close, .lb-prev, .lb-next { position: fixed; background: rgba(255,255,255,0.1); border: none; color: #fff; cursor: pointer; border-radius: 50%; width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; transition: background 0.25s; backdrop-filter: blur(4px); }
  .lb-close:hover, .lb-prev:hover, .lb-next:hover { background: rgba(255,255,255,0.2); }
  .lb-close { top: 1.5rem; right: 1.5rem; font-size: 1.8rem; }
  .lb-prev  { left: 1.5rem; top: 50%; transform: translateY(-50%); font-size: 2rem; }
  .lb-next  { right: 1.5rem; top: 50%; transform: translateY(-50%); font-size: 2rem; }
</style>
