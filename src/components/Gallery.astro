---
// Gallery.astro — shows max 5 images, 6th slot is "Ver más →" card
interface GalleryImage {
  id: number;
  url: string;
  caption: string | null;
  order: number;
}
interface Props {
  images: GalleryImage[];
}
const { images } = Astro.props;
const PREVIEW_COUNT = 5;
const previewImages = images.slice(0, PREVIEW_COUNT);
const hasMore = images.length > PREVIEW_COUNT;
---
<section class="gallery-section fade-up" id="galeria">
  <div class="gallery-container">
    <p class="section-label">Momentos</p>
    <h2 class="section-heading">Nuestra Historia</h2>
    <div class="section-ornament"><span>❧</span></div>
    <p class="section-subhead">Cada imagen cuenta una parte de nuestra historia de amor.</p>

    {images.length === 0 ? (
      <div class="gallery-empty-state">
        <div class="empty-icon">📷</div>
        <h4>Pronto compartiremos nuestros recuerdos</h4>
        <p>Aún estamos construyendo esta galería con nuestros mejores momentos.</p>
      </div>
    ) : (
      <div class="gallery-grid" id="gallery-grid">
        {previewImages.map((img, i) => (
          <div
            class={`gallery-item ${img.orientation && img.orientation !== 'auto' ? `orient-${img.orientation}` : ''}`}
            style={`animation-delay: ${i * 0.1}s`}
            data-src={img.url}
            data-caption={img.caption || ''}
            role="button"
            tabindex="0"
            aria-label={img.caption || 'Ver foto'}
          >
            <img src={img.url} alt={img.caption || 'Galería de boda'} loading="lazy" />
            {img.caption && (
              <div class="item-overlay">
                <p class="item-caption">{img.caption}</p>
              </div>
            )}
            <div class="item-zoom-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
            </div>
          </div>
        ))}

        {/* Always show a sleek 'Ver todas' card at the end if there's at least 1 photo */}
        {images.length > 0 && (
          <a href="/galeria" class="gallery-item gallery-more" style={`animation-delay: ${previewImages.length * 0.1}s`}>
            <div class="more-bg">
              <img src={images[0].url} alt="" aria-hidden="true" />
              <div class="more-overlay"></div>
            </div>
            <div class="more-content">
              <span class="more-icon">✧</span>
              <p class="more-label">Ver galería<br/>completa</p>
              {hasMore ? (
                 <span class="more-count">+{images.length - PREVIEW_COUNT} fotos</span>
              ) : (
                 <span class="more-count">Ver todas</span>
              )}
              <svg class="more-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </div>
          </a>
        )}
      </div>
    )}
  </div>
</section>

<!-- Lightbox -->
<div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-hidden="true">
  <button class="lb-close" id="lb-close" aria-label="Cerrar">&times;</button>
  <button class="lb-prev" id="lb-prev" aria-label="Anterior">&#8249;</button>
  <button class="lb-next" id="lb-next" aria-label="Siguiente">&#8250;</button>
  <div class="lb-content">
    <img id="lb-img" src="" alt="" />
    <p id="lb-caption" class="lb-caption"></p>
  </div>
</div>

<script>
  const items = Array.from(document.querySelectorAll('.gallery-item:not(.gallery-more)')) as HTMLElement[];
  const lightbox = document.getElementById('lightbox')!;
  const lbImg = document.getElementById('lb-img') as HTMLImageElement;
  const lbCaption = document.getElementById('lb-caption')!;
  let currentIndex = 0;

  function openLightbox(index: number) {
    currentIndex = index;
    const item = items[index];
    lbImg.src = item.dataset.src!;
    lbCaption.textContent = item.dataset.caption || '';
    lightbox.classList.add('active');
    lightbox.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    lbImg.classList.remove('loaded');
    lbImg.onload = () => lbImg.classList.add('loaded');
  }

  function closeLightbox() {
    lightbox.classList.remove('active');
    lightbox.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  items.forEach((item, i) => {
    item.addEventListener('click', () => openLightbox(i));
    item.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openLightbox(i); }
    });
  });

  document.getElementById('lb-close')!.addEventListener('click', closeLightbox);
  document.getElementById('lb-prev')!.addEventListener('click', () => openLightbox((currentIndex - 1 + items.length) % items.length));
  document.getElementById('lb-next')!.addEventListener('click', () => openLightbox((currentIndex + 1) % items.length));
  lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('active')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') openLightbox((currentIndex - 1 + items.length) % items.length);
    if (e.key === 'ArrowRight') openLightbox((currentIndex + 1) % items.length);
  });
</script>

<style>
  .gallery-section { padding: 8rem 1.5rem; background: var(--color-ivory); }
  .gallery-container { max-width: 1100px; margin: 0 auto; text-align: center; }
  .section-label { font-family: 'Montserrat', sans-serif; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.35em; text-transform: uppercase; color: var(--color-gold); margin: 0 0 0.75rem; }
  .section-heading { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.2rem, 5vw, 3.5rem); font-weight: 400; color: var(--color-forest); margin: 0 0 0.5rem; }
  .section-subhead { font-size: 0.9rem; color: var(--color-text-muted); margin: 0.5rem 0 3.5rem; }
  .gallery-grid {
    columns: 3;
    column-gap: 1.25rem;
  }
  @media (max-width: 900px) { .gallery-grid { columns: 2; } }
  @media (max-width: 500px) { .gallery-grid { columns: 1; } }
  
  .gallery-item {
    break-inside: avoid;
    margin-bottom: 1.25rem;
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    cursor: pointer;
    background: #e9e5df;
    opacity: 0;
    animation: fadeInUp 0.8s ease forwards;
  }
  @keyframes fadeInUp { 
    from { opacity: 0; transform: translateY(20px); } 
    to { opacity: 1; transform: translateY(0); } 
  }
  .gallery-item.orient-horizontal { grid-row: span 1; }
  .gallery-item.orient-vertical { grid-row: span 2; }
  .gallery-item img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .item-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(44,74,62,0.85) 0%, transparent 60%); border-radius: 16px; opacity: 0; transition: opacity 0.3s ease; display: flex; align-items: flex-end; padding: 1.25rem; }
  .gallery-item:hover .item-overlay { opacity: 1; }
  .item-caption { font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; color: #fff; margin: 0; font-style: italic; }
  .item-zoom-icon { position: absolute; top: 1rem; right: 1rem; width: 36px; height: 36px; background: rgba(255,255,255,0.15); backdrop-filter: blur(6px); border-radius: 50%; display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.3s; color: white; }
  .item-zoom-icon svg { width: 16px; height: 16px; }
  .gallery-item:hover .item-zoom-icon { opacity: 1; }

  /* ── Ver más card ── */
  .gallery-more {
    display: block; text-decoration: none;
    position: relative;
    aspect-ratio: 1 / 1;
    border-radius: 16px;
    overflow: hidden;
    break-inside: avoid;
    opacity: 0;
    animation: fadeInUp 0.6s ease forwards;
  }
  .more-bg { position: absolute; inset: 0; }
  .more-bg img { width: 100%; height: 100%; object-fit: cover; filter: blur(4px) brightness(0.4); transform: scale(1.05); transition: transform 0.5s; }
  .gallery-more:hover .more-bg img { transform: scale(1.1); filter: blur(2px) brightness(0.4); }
  .more-overlay { position: absolute; inset: 0; background: linear-gradient(160deg, rgba(44,74,62,0.85), rgba(10,20,15,0.9)); }
  .more-content { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; gap: 1rem; padding: 1.5rem; color: white; border: 1px solid rgba(201,169,110,0.15); border-radius: 16px; margin: 4px; }
  .more-icon { font-size: 2rem; color: var(--color-gold); line-height: 1; opacity: 0.8; }
  .more-count { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; font-style: italic; color: var(--color-gold-light); line-height: 1; margin: 0; }
  .more-label { font-family: 'Montserrat', sans-serif; font-size: 0.82rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; margin: 0; text-align: center; color: rgba(255,255,255,0.95); }
  .more-arrow { width: 20px; height: 20px; color: var(--color-gold); transition: transform 0.3s; margin-top: 0.5rem; }
  .gallery-more:hover .more-arrow { transform: translateX(5px); color: #fff; }

  /* ── Lightbox ── */
  .lightbox { position: fixed; inset: 0; background: rgba(15,30,22,0.98); z-index: 9999; display: flex; flex-direction: column; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity 0.4s ease; backdrop-filter: blur(10px); }
  .lightbox.active { opacity: 1; pointer-events: auto; }
  
  .gallery-empty-state { text-align: center; padding: 4rem 1rem; background: rgba(201,169,110,0.05); border: 1px dashed rgba(201,169,110,0.3); border-radius: 16px; max-width: 600px; margin: 0 auto; }
  .empty-icon { font-size: 3rem; margin-bottom: 1rem; opacity: 0.6; }
  .gallery-empty-state h4 { font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; color: var(--color-forest); margin: 0 0 0.5rem; }
  .gallery-empty-state p { color: #666; font-size: 0.95rem; margin: 0; }

  .lb-content { max-width: 90vw; max-height: 90vh; display: flex; flex-direction: column; align-items: center; gap: 1rem; }
  #lb-img { max-width: 90vw; max-height: 80vh; border-radius: 12px; object-fit: contain; opacity: 0; transition: opacity 0.3s ease; }
  #lb-img.loaded { opacity: 1; }
  .lb-caption { font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; color: rgba(255,255,255,0.7); margin: 0; font-style: italic; }
  .lb-close, .lb-prev, .lb-next { position: fixed; background: rgba(255,255,255,0.1); border: none; color: #fff; cursor: pointer; border-radius: 50%; width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; transition: background 0.25s; backdrop-filter: blur(4px); }
  .lb-close:hover, .lb-prev:hover, .lb-next:hover { background: rgba(255,255,255,0.2); }
  .lb-close { top: 1.5rem; right: 1.5rem; font-size: 1.8rem; }
  .lb-prev  { left: 1.5rem; top: 50%; transform: translateY(-50%); font-size: 2rem; }
  .lb-next  { right: 1.5rem; top: 50%; transform: translateY(-50%); font-size: 2rem; }
</style>
