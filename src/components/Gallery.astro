---
// Gallery.astro
const images = [
  { src: 'https://images.unsplash.com/photo-1530103862676-de8c9debad1d?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80', alt: 'Arreglo de Globos', category: 'Globos' },
  { src: 'https://images.unsplash.com/photo-1519225421980-715cb0215aed?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80', alt: 'Decoración Bodas', category: 'Eventos' },
  { src: 'https://images.unsplash.com/photo-1561571994-3c61c554181a?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80', alt: 'Letrero Neon', category: 'Letreros' },
  { src: 'https://images.unsplash.com/photo-1520854221256-17451cc331bf?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80', alt: 'Detalles en Resina', category: 'Resina' },
  { src: 'https://images.unsplash.com/photo-1464366400600-7168b8af9bc3?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80', alt: 'Mesa Dulce decorada', category: 'Eventos' },
  { src: 'https://images.unsplash.com/photo-1513151233558-d860c5398176?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80', alt: 'Artesanía Decorativa', category: 'Styrofoam' },
];
---
<section class="gallery" id="gallery">
  <div class="container">
    <div class="gallery-header fade-in">
      <p class="section-label">Portafolio</p>
      <h2 class="section-title">Galería de <em>Proyectos</em></h2>
      <p class="gallery-intro">
        Explora algunas de nuestras creaciones más destacadas. Cada proyecto es diseñado a 
        medida para contar la historia única de nuestros clientes.
      </p>
    </div>

    <div class="gallery-grid">
      {images.map((img, index) => (
        <div class={`gallery-item fade-in d-${(index % 4) + 1}`}>
          <img src={img.src} alt={img.alt} class="gallery-img" loading="lazy" />
          <div class="gallery-overlay">
            <span class="gallery-category">{img.category}</span>
            <h4 class="gallery-item-title">{img.alt}</h4>
          </div>
        </div>
      ))}
    </div>
    
    <div class="gallery-cta fade-in">
      <a href="https://instagram.com" target="_blank" rel="noopener" class="btn btn-outline">
        Ver más en nuestro Instagram
      </a>
    </div>
  </div>
</section>

<style>
.gallery {
  background: var(--color-bg);
}

.gallery-header {
  text-align: center;
  max-width: 600px;
  margin: 0 auto 4rem;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.gallery-header .section-label {
  justify-content: center;
}
.gallery-header .section-label::before {
  display: none;
}

.gallery-intro {
  color: var(--color-text);
  font-size: var(--size-md);
  margin-top: -0.5rem;
}

.gallery-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1.5rem;
}

.gallery-item {
  position: relative;
  aspect-ratio: 1;
  border-radius: var(--radius-md);
  overflow: hidden;
  cursor: pointer;
}

.gallery-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.gallery-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(43, 40, 38, 0.8) 0%, rgba(43, 40, 38, 0) 50%);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 1.5rem;
  opacity: 0;
  transition: opacity 0.4s ease;
}

.gallery-item:hover .gallery-img {
  transform: scale(1.05);
}
.gallery-item:hover .gallery-overlay {
  opacity: 1;
}

.gallery-category {
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--color-accent);
  font-weight: 700;
  margin-bottom: 0.25rem;
}

.gallery-item-title {
  color: white;
  font-family: var(--font-serif);
  font-size: var(--size-lg);
  font-weight: 400;
}

.gallery-cta {
  margin-top: 4rem;
  text-align: center;
}

@media (max-width: 768px) {
  .gallery-grid {
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
  }
}
</style>
