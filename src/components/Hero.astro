---
// Hero.astro — Dynamic content from Settings
interface Props {
  heroTitle: string;
  heroSubtitle: string;
  weddingDate: string;
  receptionVenue: string;
}
const { heroTitle, heroSubtitle, receptionVenue } = Astro.props;
---
<section class="hero-section">
  <div class="hero-bg" aria-hidden="true"></div>
  <div class="hero-overlay" aria-hidden="true"></div>

  <!-- Floating petals decoration -->
  <div class="petals" aria-hidden="true">
    {Array.from({length: 8}).map((_, i) => (
      <span class="petal" style={`--delay:${i*0.7}s; --x:${10+i*11}%`}>✿</span>
    ))}
  </div>

  <div class="hero-content fade-up visible">
    <div class="elegant-badge">¡Nos Casamos!</div>
    
    <div class="title-wrapper">
      <h1 set:html={heroTitle.replace('&', '<span class="ampersand">&</span>')}></h1>
    </div>

    <div class="section-ornament hero-ornament">
      <span>❧</span>
    </div>

    <p class="date-line">{heroSubtitle}</p>
    
    <div class="hero-cta">
      <a href="#rsvp" class="btn btn-hero">Confirma tu asistencia</a>
      <a href="/galeria" class="btn btn-outline-hero">Ver Galería</a>
    </div>
  </div>

  <div class="scroll-hint" aria-hidden="true">
    <span></span>
  </div>
</section>

<script>
  const heroBg = document.querySelector('.hero-bg') as HTMLElement | null;
  window.addEventListener('scroll', () => {
    if (heroBg) {
      heroBg.style.transform = `translateY(${window.scrollY * 0.4}px)`;
    }
  }, { passive: true });
</script>

<style>
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
    padding: 2rem 1.5rem;
  }

  .hero-bg {
    position: absolute;
    inset: -5%;
    background-image: url('https://images.unsplash.com/photo-1519225421980-715cb0215aed?q=80&w=2070&auto=format&fit=crop');
    background-size: cover;
    background-position: center;
    will-change: transform;
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(15, 30, 22, 0.65) 0%,
      rgba(15, 30, 22, 0.4) 50%,
      rgba(15, 30, 22, 0.85) 100%
    );
    z-index: 1;
  }

  /* Floating petals */
  .petals {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }
  .petal {
    position: absolute;
    top: -10%;
    left: var(--x);
    color: rgba(224, 201, 155, 0.25);
    font-size: clamp(0.8rem, 2vw, 1.4rem);
    animation: petalFall 8s ease-in infinite;
    animation-delay: var(--delay);
  }
  @keyframes petalFall {
    0%   { transform: translateY(0) rotate(0deg); opacity: 0; }
    10%  { opacity: 1; }
    100% { transform: translateY(110vh) rotate(720deg); opacity: 0; }
  }

  .hero-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .elegant-badge {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--color-gold-light);
    margin-bottom: 2rem;
    padding: 0.5rem 1.5rem;
    border: 1px solid rgba(224, 201, 155, 0.3);
    border-radius: var(--radius-pill);
    background: rgba(44, 74, 62, 0.4);
    backdrop-filter: blur(4px);
  }

  .title-wrapper h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3.5rem, 10vw, 7.5rem);
    font-weight: 400;
    color: #ffffff;
    margin: 0;
    letter-spacing: 0.04em;
    text-shadow: 0 4px 16px rgba(0,0,0,0.5);
  }

  :global(.ampersand) {
    color: var(--color-gold-light);
    font-style: italic;
    text-shadow: 0 2px 4px rgba(0,0,0,0.4);
  }

  .hero-ornament {
    margin: 1.5rem auto 1.5rem;
  }
  .hero-ornament::before,
  .hero-ornament::after {
    max-width: 60px;
    background: rgba(224, 201, 155, 0.6);
  }
  .hero-ornament span { color: var(--color-gold-light); }

  .date-line {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.3rem, 3vw, 1.8rem);
    font-weight: 300;
    font-style: italic;
    color: #ffffff;
    margin: 0 0 0.5rem;
    letter-spacing: 0.03em;
  }

  .venue-line {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-gold-light);
    margin: 0 0 2.5rem;
    opacity: 0.85;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .btn-outline-hero {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    color: rgba(255,255,255,0.9);
    border: 2px solid rgba(255,255,255,0.5);
    padding: 0.85rem 2.4rem;
    font-size: 0.8rem;
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    border-radius: var(--radius-pill);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .btn-outline-hero {
    background: transparent;
    color: #ffffff;
    border: 2px solid rgba(255, 255, 255, 0.4);
  }
  .btn-outline-hero:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: #ffffff;
  }

  @media (max-width: 768px) {
    .hero-section { padding: 4rem 1rem; }
    .title-wrapper h1 { font-size: 4rem; margin-bottom: 0.5rem; }
    .hero-cta { flex-direction: column; width: 100%; max-width: 280px; gap: 0.75rem; }
    .btn { width: 100%; padding: 1rem 1.5rem; }
    .elegant-badge { font-size: 0.65rem; margin-bottom: 1.5rem; }
  }

  .scroll-hint {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
  }
  .scroll-hint span {
    display: block;
    width: 20px;
    height: 20px;
    border-right: 1.5px solid rgba(224, 201, 155, 0.7);
    border-bottom: 1.5px solid rgba(224, 201, 155, 0.7);
    transform: rotate(45deg);
    animation: scrollBounce 1.6s ease-in-out infinite;
  }
  @keyframes scrollBounce {
    0%, 100% { transform: rotate(45deg) translateY(0); opacity: 0.5; }
    50%       { transform: rotate(45deg) translateY(6px); opacity: 1; }
  }
</style>
