---
import settings from '../data/settings.json';
---
// Hero.astro
---
<section class="hero">
  <div class="container hero-container">
    <div class="hero-content">
      <div class="hero-tag fade-in float-anim">{settings.heroTag}</div>
      <h1 class="hero-title fade-in d-1" id="hero-heading">
        {settings.heroTitle}
      </h1>
      <p class="hero-subtitle fade-in d-2">
        {settings.heroSubtitle}
      </p>
      <div class="hero-actions hero-anim d-4">
        <a href="#gallery" class="btn btn-primary">Ver trabajos</a>
        <a href="#contact" class="btn btn-outline">Solicitar información</a>
      </div>
    </div>
    
    <div class="hero-visual hero-anim d-4">
      <div class="image-wrapper">
        <!-- Placeholder elegante simulando una decoración con globos / letrero neon -->
        <img 
          src={settings.heroImage} 
          alt="Decoración hero" 
          class="hero-img float-anim"
          style="animation-duration: 8s"
        />
        <div class="deco-shape float-anim"></div>
      </div>
    </div>
  </div>
</section>

<style>
.hero {
  min-height: 100vh;
  display: flex;
  align-items: center;
  padding-top: 80px; /* offset header */
  background: var(--color-bg);
  position: relative;
  overflow: hidden;
}

/* Fondo decorativo sutil */
.hero::before {
  content: '';
  position: absolute;
  top: -10%;
  right: -5%;
  width: 50vw;
  height: 50vw;
  border-radius: 50%;
  background: radial-gradient(circle, var(--color-accent-dim) 0%, transparent 70%);
  z-index: 0;
}

.hero-container {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
  position: relative;
  z-index: 1;
}

.hero-content {
  max-width: 550px;
}

.hero-tag {
  display: inline-block;
  font-size: var(--size-xs);
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--color-accent-dark);
  margin-bottom: 1.5rem;
  background: var(--color-surface);
  padding: 0.4rem 1rem;
  border-radius: var(--radius-full);
  box-shadow: 0 4px 20px rgba(0,0,0,0.03);
}

.hero-title {
  font-family: var(--font-serif);
  font-size: clamp(3rem, 5vw, 4.5rem);
  line-height: 1.1;
  color: var(--color-heading);
  margin-bottom: 1.5rem;
}
.hero-title em {
  font-style: italic;
  color: var(--color-accent-dark);
}

.hero-subtitle {
  font-size: var(--size-lg);
  color: var(--color-text);
  margin-bottom: 2.5rem;
  line-height: 1.7;
}

.hero-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

/* -- Visual Side -- */
.hero-visual {
  position: relative;
}

.image-wrapper {
  position: relative;
  border-radius: 200px 200px 0 0;
  overflow: hidden;
  height: 600px;
  box-shadow: 0 20px 50px rgba(0,0,0,0.05);
}

.hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.7s ease;
}
.image-wrapper:hover .hero-img {
  transform: scale(1.05);
}

.deco-shape {
  position: absolute;
  bottom: -20px;
  left: -20px;
  width: 150px;
  height: 150px;
  border: 2px solid var(--color-accent);
  border-radius: 50%;
  z-index: -1;
}

@media (max-width: 968px) {
  .hero-container {
    grid-template-columns: 1fr;
    text-align: center;
  }
  .hero-content {
    max-width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .hero-actions {
    justify-content: center;
  }
  .image-wrapper {
    height: 400px;
    border-radius: var(--radius-xl);
    max-width: 500px;
    margin: 0 auto;
  }
}
</style>
