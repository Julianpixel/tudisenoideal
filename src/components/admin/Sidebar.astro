---
const { currentPath } = Astro.props;
---
<aside class="sidebar">
  <div class="sidebar-brand">
    <span class="brand-icon">❧</span>
    <span class="brand-name">Wedding<br/>Admin</span>
  </div>
  <nav class="sidebar-nav">
    <a href="/admin/dashboard" class={`nav-item ${currentPath === '/admin/dashboard' ? 'active' : ''}`}>
      <span>📊</span> Dashboard
    </a>
    <a href="/admin/contenido" class={`nav-item ${currentPath === '/admin/contenido' ? 'active' : ''}`}>
      <span>✏️</span> Contenido
    </a>
    <a href="/admin/galeria" class={`nav-item ${currentPath === '/admin/galeria' ? 'active' : ''}`}>
      <span>🖼️</span> Galería
    </a>
    <a href="/admin/mesas" class={`nav-item ${currentPath === '/admin/mesas' ? 'active' : ''}`}>
      <span>🪑</span> Mesas
    </a>
    <a href="/admin/grupos" class={`nav-item ${currentPath === '/admin/grupos' ? 'active' : ''}`}>
      <span>👥</span> Grupos
    </a>
    <a href="/admin/donaciones" class={`nav-item ${currentPath === '/admin/donaciones' ? 'active' : ''}`}>
      <span>💳</span> Donaciones
    </a>
    <a href="/admin/logout" class="nav-item nav-logout">
      <span>🚪</span> Salir
    </a>
  </nav>
</aside>

<style>
  .sidebar { width: 220px; flex-shrink: 0; background: var(--color-forest); display: flex; flex-direction: column; padding: 2rem 0; position: sticky; top: 0; height: 100vh; overflow-y: auto; z-index: 100; transition: all 0.3s ease; }
  .sidebar-brand { display: flex; align-items: center; gap: 0.75rem; padding: 0 1.5rem 2rem; border-bottom: 1px solid rgba(255,255,255,0.1); margin-bottom: 1.5rem; }
  .brand-icon { font-size: 1.5rem; color: var(--color-gold); }
  .brand-name { font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; line-height: 1.3; color: rgba(255,255,255,0.9); }
  .sidebar-nav { display: flex; flex-direction: column; gap: 0.25rem; padding: 0 0.75rem; flex: 1; }
  .nav-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 0.85rem; border-radius: 10px; color: rgba(255,255,255,0.65); text-decoration: none; font-size: 0.82rem; font-weight: 500; transition: background 0.25s, color 0.25s; white-space: nowrap; }
  .nav-item svg { width: 18px; height: 18px; flex-shrink: 0; }
  .nav-item:hover { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.9); }
  .nav-item.active { background: rgba(201,169,110,0.2); color: var(--color-gold-light); font-weight: 600; }
  .nav-logout { margin-top: auto; }

  @media (max-width: 1024px) {
    .sidebar { 
      width: 100% !important; 
      height: auto !important; 
      min-height: auto !important; 
      position: sticky !important; 
      top: 0 !important; 
      left: 0 !important;
      flex-direction: row !important; 
      padding: 0.6rem 0.75rem !important; 
      border-bottom: 2px solid rgba(255,255,255,0.1) !important; 
      box-shadow: 0 4px 15px rgba(0,0,0,0.2) !important;
      z-index: 9999 !important;
    }
    .sidebar-brand { padding: 0 !important; border-bottom: none !important; margin-bottom: 0 !important; margin-right: 1rem !important; }
    .brand-name { display: none !important; }
    .sidebar-nav { flex-direction: row !important; gap: 0.5rem !important; padding: 0 !important; overflow-x: auto !important; flex: 1 !important; scrollbar-width: none !important; }
    .sidebar-nav::-webkit-scrollbar { display: none !important; }
    .nav-item { padding: 0.5rem 0.75rem !important; font-size: 0.7rem !important; background: rgba(255,255,255,0.05) !important; border-radius: 8px !important; }
    .nav-logout { margin-top: 0 !important; margin-left: auto !important; }
  }
</style>
