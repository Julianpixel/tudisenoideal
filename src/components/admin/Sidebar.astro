---
const { currentPath } = Astro.props;
---
<aside class="sidebar">
  <div class="sidebar-brand">
    <span class="brand-icon">❧</span>
    <span class="brand-name">Wedding<br/>Admin</span>
  </div>
  <nav class="sidebar-nav">
    <a href="/admin/dashboard" class={`nav-item ${currentPath === '/admin/dashboard' ? 'active' : ''}`}>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7" rx="2"/><rect x="14" y="3" width="7" height="7" rx="2"/><rect x="14" y="14" width="7" height="7" rx="2"/><rect x="3" y="14" width="7" height="7" rx="2"/></svg>
      Dashboard
    </a>
    <a href="/admin/contenido" class={`nav-item ${currentPath === '/admin/contenido' ? 'active' : ''}`}>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
      Contenido
    </a>
    <a href="/admin/galeria" class={`nav-item ${currentPath === '/admin/galeria' ? 'active' : ''}`}>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
      Galería
    </a>
    <a href="/admin/mesas" class={`nav-item ${currentPath === '/admin/mesas' ? 'active' : ''}`}>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="3"/><path d="M12 3v3M12 18v3M3 12h3M18 12h3"/></svg>
      Mesas
    </a>
    <a href="/admin/grupos" class={`nav-item ${currentPath === '/admin/grupos' ? 'active' : ''}`}>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
      Grupos Familiares
    </a>
    <a href="/admin/donaciones" class={`nav-item ${currentPath === '/admin/donaciones' ? 'active' : ''}`}>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
      Donaciones
    </a>
    <a href="/admin/logout" class="nav-item nav-logout">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/></svg>
      Cerrar Sesión
    </a>
  </nav>
</aside>

<style>
  .sidebar { width: 220px; flex-shrink: 0; background: var(--color-forest); display: flex; flex-direction: column; padding: 2rem 0; position: sticky; top: 0; height: 100vh; }
  .sidebar-brand { display: flex; align-items: center; gap: 0.75rem; padding: 0 1.5rem 2rem; border-bottom: 1px solid rgba(255,255,255,0.1); margin-bottom: 1.5rem; }
  .brand-icon { font-size: 1.5rem; color: var(--color-gold); }
  .brand-name { font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; line-height: 1.3; color: rgba(255,255,255,0.9); }
  .sidebar-nav { display: flex; flex-direction: column; gap: 0.25rem; padding: 0 0.75rem; flex: 1; }
  .nav-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 0.85rem; border-radius: 10px; color: rgba(255,255,255,0.65); text-decoration: none; font-size: 0.82rem; font-weight: 500; transition: background 0.25s, color 0.25s; }
  .nav-item svg { width: 18px; height: 18px; flex-shrink: 0; }
  .nav-item:hover { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.9); }
  .nav-item.active { background: rgba(201,169,110,0.2); color: var(--color-gold-light); font-weight: 600; }
  .nav-logout { margin-top: auto; }
</style>
