---
// Contact.astro
---
<section class="contact" id="contact">
  <div class="container contact-container">
    <div class="contact-info fade-in d-1">
      <p class="section-label">Hablemos</p>
      <h2 class="section-title">¿Listo para hacer tu <em>idea realidad</em>?</h2>
      <p class="contact-desc">
        Nos encantaría conocer los detalles de tu próximo evento. Escríbenos para 
        cotizaciones sin compromiso, dudas sobre materiales o para reservar tu fecha.
      </p>
      
      <div class="contact-details">
        <div class="contact-item">
          <svg viewBox="0 0 24 24" fill="none" class="contact-icon" stroke="currentColor" stroke-width="1.5">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          <div>
            <strong>WhatsApp o Llamadas</strong>
            <p>+1 (555) 123-4567</p>
          </div>
        </div>
        
        <div class="contact-item">
          <svg viewBox="0 0 24 24" fill="none" class="contact-icon" stroke="currentColor" stroke-width="1.5">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          <div>
            <strong>Email</strong>
            <p>hola@tudisenoideal.com</p>
          </div>
        </div>
      </div>
    </div>
    
    <div class="contact-form-wrap fade-in d-2">
      <form class="contact-form" onsubmit="event.preventDefault();">
        <div class="form-group">
          <label for="name">Nombre</label>
          <input type="text" id="name" placeholder="Tu nombre" required />
        </div>
        
        <div class="form-group">
          <label for="phone">Teléfono / WhatsApp</label>
          <input type="tel" id="phone" placeholder="Tu número de contacto" required />
        </div>
        
        <div class="form-group">
          <label for="message">Cuéntanos sobre tu evento</label>
          <textarea id="message" rows="4" placeholder="Tipo de evento, fecha tentativa, ideas..." required></textarea>
        </div>
        
        <button type="submit" class="btn btn-primary w-full">Enviar Mensaje</button>
        
        <div class="whatsapp-alt">
          <span>O escríbenos directo por</span>
          <a href="https://wa.me/15551234567" target="_blank" rel="noopener" class="btn btn-outline whatsapp-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="wa-icon">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
            </svg>
            WhatsApp
          </a>
        </div>
      </form>
    </div>
  </div>
</section>

<style>
.contact {
  background: var(--color-bg);
  position: relative;
}

.contact-container {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 5rem;
  align-items: center;
}

.contact-info {
  max-width: 450px;
}

.contact-desc {
  font-size: var(--size-md);
  color: var(--color-text);
  margin-bottom: 2.5rem;
  line-height: 1.7;
}

.contact-details {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.contact-item {
  display: flex;
  align-items: center;
  gap: 1.25rem;
}

.contact-icon {
  width: 24px; height: 24px;
  color: var(--color-accent-dark);
}

.contact-item strong {
  display: block;
  font-size: var(--size-sm);
  color: var(--color-heading);
  font-family: var(--font-serif);
  margin-bottom: 0.2rem;
}

.contact-item p {
  color: var(--color-text);
  font-size: var(--size-md);
}

/* -- Form -- */
.contact-form-wrap {
  background: var(--color-surface);
  padding: 3rem;
  border-radius: var(--radius-lg);
  box-shadow: 0 15px 40px rgba(0,0,0,0.04);
  border: 1px solid var(--color-border);
}

.contact-form {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.form-group label {
  font-size: var(--size-xs);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--color-heading);
}

.form-group input,
.form-group textarea {
  width: 100%;
  padding: 1rem;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  background: var(--color-bg);
  font-family: var(--font-sans);
  font-size: var(--size-sm);
  color: var(--color-text);
  transition: border-color var(--transition), box-shadow var(--transition);
}

.form-group input:focus,
.form-group textarea:focus {
  outline: none;
  border-color: var(--color-accent-dark);
  box-shadow: 0 0 0 3px var(--color-accent-dim);
}

.w-full {
  width: 100%;
  justify-content: center;
  margin-top: 0.5rem;
}

.whatsapp-alt {
  margin-top: 2rem;
  padding-top: 1.5rem;
  border-top: 1px solid var(--color-border);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
}

.whatsapp-alt span {
  font-size: var(--size-xs);
  color: var(--color-text);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.whatsapp-btn {
  width: 100%;
}
.wa-icon {
  width: 18px; height: 18px;
}

@media (max-width: 900px) {
  .contact-container {
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  .contact-form-wrap {
    padding: 2rem 1.5rem;
  }
}
</style>
