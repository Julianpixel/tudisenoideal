---
import '../styles/global.css';
import settings from '../data/settings.json';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Tu Diseño ideal | Decoraciones Personalizadas y Eventos',
  description = 'Transformamos ideas en decoraciones únicas. Letreros, styrofoam, resina y arreglos con globos para tus eventos especiales.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Tu Diseño ideal" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
  </head>

  <body>
    <!-- HEADER -->
    <header class="header">
      <div class="container header-inner">
        <a href="/" class="logo">
          Tu Diseño <em>ideal</em>
        </a>
        <nav class="nav">
          <ul class="nav-list">
            <li><a href="/#about">Nosotros</a></li>
            <li><a href="/#services">Servicios</a></li>
            <li><a href="/galeria">Galería</a></li>
            <li><a href="/#why-us">Por qué elegirnos</a></li>
          </ul>
        </nav>
        <div class="header-actions" style="display: flex; align-items: center; gap: 1rem;">
          <a href="/admin" aria-label="Admin Panel" class="admin-link" style="color: var(--color-text-light); transition: color 0.3s ease; display: flex;" title="Panel de Administración">
            <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
          </a>
          <a href="#contact" class="btn btn-primary nav-btn">Cotizar</a>
        </div>
        
        <!-- Mobile Menu Toggle -->
        <button class="mobile-toggle" aria-label="Abrir menú">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </button>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- FOOTER -->
    <footer class="footer">
      <div class="container footer-inner">
        <div class="footer-brand">
          <a href="/" class="logo logo-footer" style="display: flex; align-items: center; gap: 0.6rem;">
            {settings.footerLogo && (
              <img src={settings.footerLogo} alt="Logo Tu Diseño Ideal" style="width: 40px; height: 40px; object-fit: contain; border-radius: 50%;" />
            )}
            <span>Tu Diseño <em>ideal</em></span>
          </a>
          <p style="margin-top: 0.8rem;">{settings.footerDescription || "Haz de tu evento algo inolvidable."}</p>
        </div>
        <div class="footer-contact">
          <h4>Contacto</h4>
          <p>Email: {settings.contactEmail}</p>
          <p>Teléfono: {settings.contactPhoneLabel}</p>
        </div>
        <div class="footer-social">
          <h4>Síguenos</h4>
          <div class="social-links">
            <a href="#" aria-label="Instagram">Instagram</a>
            <a href="#" aria-label="Facebook">Facebook</a>
            <a href="#" aria-label="Pinterest">Pinterest</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom container">
        <p>&copy; {new Date().getFullYear()} {settings.footerCopyright}. Todos los derechos reservados.</p>
      </div>
    </footer>

    <!-- INTERSECTION OBSERVER SCRIPT FOR ANIMATIONS -->
    <script>
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      }, { threshold: 0.1 });

      document.addEventListener('DOMContentLoaded', () => {
        const fadeElements = document.querySelectorAll('.fade-in');
        fadeElements.forEach(el => observer.observe(el));

        // Magnetic Buttons Logic
        const magneticBtns = document.querySelectorAll('.btn');
        magneticBtns.forEach(btn => {
          btn.addEventListener('mousemove', (e) => {
            const rect = btn.getBoundingClientRect();
            const calcX = (e.clientX - rect.left - rect.width / 2) * 0.3;
            const calcY = (e.clientY - rect.top - rect.height / 2) * 0.3;
            btn.style.transform = `translate(${calcX}px, ${calcY}px)`;
          });
          btn.addEventListener('mouseleave', () => {
            btn.style.transform = `translate(0px, 0px)`;
          });
        });
      });
    </script>
  </body>
</html>

<style>
/* ---- HEADER ---- */
.header {
  position: fixed;
  top: 0;
  width: 100%;
  background: rgba(252, 251, 249, 0.9);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  z-index: 1000;
  border-bottom: 1px solid var(--color-border);
  transition: padding 0.3s ease, background 0.3s ease;
}

.header-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 80px;
}

.logo {
  font-family: var(--font-serif);
  font-size: var(--size-xl);
  color: var(--color-heading);
  letter-spacing: -0.02em;
}
.logo em {
  color: var(--color-accent-dark);
  font-style: italic;
}

.nav-list {
  display: flex;
  gap: 2.5rem;
}
.nav-list a {
  font-size: var(--size-sm);
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--color-text);
  transition: color var(--transition);
  position: relative;
}
.nav-list a:hover {
  color: var(--color-accent-dark);
}

.nav-btn {
  padding: 0.6rem 1.5rem;
}

.mobile-toggle {
  display: none;
  color: var(--color-heading);
}

/* ---- FOOTER ---- */
.footer {
  background: var(--color-surface);
  border-top: 1px solid var(--color-border);
  padding-top: 5rem;
  padding-bottom: 2rem;
}

.footer-inner {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  gap: 3rem;
  margin-bottom: 3rem;
}

.footer-brand {
  max-width: 300px;
}
.logo-footer {
  display: inline-block;
  margin-bottom: 1rem;
}
.footer-slogan {
  color: var(--color-text);
  font-size: var(--size-sm);
}

.footer h4 {
  font-family: var(--font-serif);
  color: var(--color-heading);
  font-size: var(--size-lg);
  margin-bottom: 1.5rem;
  font-weight: 400;
}
.footer p {
  color: var(--color-text);
  font-size: var(--size-sm);
  margin-bottom: 0.5rem;
}

.social-links {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.social-links a {
  color: var(--color-text);
  font-size: var(--size-sm);
  transition: color var(--transition);
}
.social-links a:hover {
  color: var(--color-accent-dark);
}

.footer-bottom {
  text-align: center;
  padding-top: 2rem;
  border-top: 1px solid var(--color-border);
  color: var(--color-text);
  font-size: var(--size-xs);
}

/* ---- RESPONSIVE ---- */
@media (max-width: 860px) {
  .nav { display: none; }
  .nav-btn { display: none; }
  .mobile-toggle { display: block; }
  .footer-inner { grid-template-columns: 1fr; gap: 2rem; text-align: center; }
  .footer-brand { max-width: 100%; margin: 0 auto; }
}
</style>
