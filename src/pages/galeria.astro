---
import Layout from '../layouts/Layout.astro';

// Dummy data for the interactive gallery. This mimics a CMS or future database structure.
const portfolioItems = [
  { id: 1, src: 'https://images.unsplash.com/photo-1530103862676-de8c9debad1d?auto=format&fit=crop&w=800&q=80', alt: 'Arreglo de Globos', category: 'globos', width: 800, height: 1000 },
  { id: 2, src: 'https://images.unsplash.com/photo-1519225421980-715cb0215aed?auto=format&fit=crop&w=800&q=80', alt: 'Decoración Bodas', category: 'eventos', width: 800, height: 600 },
  { id: 3, src: 'https://images.unsplash.com/photo-1561571994-3c61c554181a?auto=format&fit=crop&w=800&q=80', alt: 'Letrero Neon', category: 'letreros', width: 800, height: 1200 },
  { id: 4, src: 'https://images.unsplash.com/photo-1520854221256-17451cc331bf?auto=format&fit=crop&w=800&q=80', alt: 'Detalles en Resina', category: 'resina', width: 800, height: 800 },
  { id: 5, src: 'https://images.unsplash.com/photo-1464366400600-7168b8af9bc3?auto=format&fit=crop&w=800&q=80', alt: 'Mesa Dulce', category: 'eventos', width: 800, height: 900 },
  { id: 6, src: 'https://images.unsplash.com/photo-1513151233558-d860c5398176?auto=format&fit=crop&w=800&q=80', alt: 'Artesanía', category: 'styrofoam', width: 800, height: 600 },
  { id: 7, src: 'https://images.unsplash.com/photo-1544457070-4cd773b4d71e?auto=format&fit=crop&w=800&q=80', alt: 'Detalle Premium', category: 'resina', width: 800, height: 1000 },
  { id: 8, src: 'https://images.unsplash.com/photo-1522064977457-37fbbf545f47?auto=format&fit=crop&w=800&q=80', alt: 'Letras 3D', category: 'styrofoam', width: 800, height: 750 },
  { id: 9, src: 'https://images.unsplash.com/photo-1511795409834-ef04bbd61622?auto=format&fit=crop&w=800&q=80', alt: 'Fiesta Cumpleaños', category: 'globos', width: 800, height: 800 },
];

const categories = [
  { val: 'all', label: 'Todos' },
  { val: 'globos', label: 'Globos' },
  { val: 'resina', label: 'Resina' },
  { val: 'letreros', label: 'Letreros' },
  { val: 'styrofoam', label: 'Styrofoam' },
  { val: 'eventos', label: 'Eventos Completos' }
];
---
<Layout title="Galería de Trabajos | Tu Diseño ideal">
  <div class="gallery-page">
    <div class="container">
      
      <header class="page-header fade-in d-1">
        <h1 class="page-title">Nuestro <em>Portafolio</em></h1>
        <p class="page-subtitle">Explora nuestra colección completa de proyectos. Puedes filtrar por categoría para encontrar inspiración para tu evento.</p>
        
        <div class="filter-group">
          {categories.map(cat => (
            <button class="filter-btn" data-filter={cat.val}>{cat.label}</button>
          ))}
        </div>
      </header>

      <div class="masonry-grid fade-in d-2" id="gallery-grid">
        {portfolioItems.map(item => (
          <div class="masonry-item" data-category={item.category}>
            <div class="item-inner" onclick={`openLightbox('${item.src}', '${item.alt}')`}>
              <img 
                src={item.src} 
                alt={item.alt} 
                loading="lazy" 
                style={`aspect-ratio: ${item.width}/${item.height}`}
              />
              <div class="item-overlay">
                <span class="zoom-icon">
                  <svg viewBox="0 0 24 24" fill="none" class="w-6 h-6" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                    <line x1="11" y1="8" x2="11" y2="14"></line>
                    <line x1="8" y1="11" x2="14" y2="11"></line>
                  </svg>
                </span>
                <p class="item-title">{item.alt}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Lightbox Modal -->
  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lb-close" aria-label="Cerrar">&times;</button>
    <div class="lightbox-content">
      <img src="" alt="" id="lb-img" />
      <p id="lb-caption" class="lightbox-caption"></p>
    </div>
  </div>
</Layout>

<style>
  .gallery-page {
    padding-top: 140px;
    padding-bottom: 8rem;
    min-height: 100vh;
    background: var(--color-bg);
  }

  .page-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 4rem;
  }

  .page-title {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 5vw, 4rem);
    color: var(--color-heading);
    margin-bottom: 1rem;
  }
  .page-title em {
    font-style: italic;
    color: var(--color-accent-dark);
  }

  .page-subtitle {
    font-size: var(--size-md);
    color: var(--color-text);
    margin-bottom: 2.5rem;
  }

  .filter-group {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }

  .filter-btn {
    padding: 0.6rem 1.5rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
    font-size: var(--size-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: all 0.3s ease;
  }
  .filter-btn:hover, .filter-btn.active {
    background: var(--color-accent-dark);
    color: white;
    border-color: var(--color-accent-dark);
  }

  /* Masonry Layout */
  .masonry-grid {
    column-count: 3;
    column-gap: 1.5rem;
  }
  @media (max-width: 900px) {
    .masonry-grid { column-count: 2; }
  }
  @media (max-width: 500px) {
    .masonry-grid { column-count: 1; }
  }

  .masonry-item {
    break-inside: avoid;
    margin-bottom: 1.5rem;
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: transform 0.4s ease, opacity 0.4s ease;
  }

  .masonry-item.hidden {
    display: none;
  }

  .item-inner {
    position: relative;
    width: 100%;
    height: 100%;
    cursor: pointer;
  }

  .item-inner img {
    width: 100%;
    display: block;
    background: #eae7e3;
    transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .item-overlay {
    position: absolute;
    inset: 0;
    background: rgba(43, 40, 38, 0.6);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .item-inner:hover img {
    transform: scale(1.05);
  }
  .item-inner:hover .item-overlay {
    opacity: 1;
  }

  .zoom-icon {
    color: white;
    width: 40px;
    height: 40px;
    margin-bottom: 1rem;
    transform: translateY(20px);
    transition: transform 0.4s ease;
  }
  .item-inner:hover .zoom-icon {
    transform: translateY(0);
  }

  .item-title {
    color: white;
    font-family: var(--font-serif);
    font-size: var(--size-lg);
    font-style: italic;
    transform: translateY(20px);
    transition: transform 0.4s ease, opacity 0.4s ease;
    opacity: 0;
  }
  .item-inner:hover .item-title {
    transform: translateY(0);
    opacity: 1;
    transition-delay: 0.1s;
  }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.95);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .lightbox.active {
    opacity: 1;
    pointer-events: all;
  }

  .lightbox-close {
    position: absolute;
    top: 2rem;
    right: 2rem;
    color: white;
    font-size: 3rem;
    line-height: 1;
    z-index: 10;
  }

  .lightbox-content {
    max-width: 90vw;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .lightbox-content img {
    max-width: 100%;
    max-height: 80vh;
    border-radius: var(--radius-sm);
    box-shadow: 0 20px 50px rgba(0,0,0,0.3);
  }

  .lightbox-caption {
    color: white;
    margin-top: 1.5rem;
    font-family: var(--font-serif);
    font-size: var(--size-lg);
    font-style: italic;
  }
</style>

<script is:inline>
  // Filtering Logic
  document.addEventListener('DOMContentLoaded', () => {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const items = document.querySelectorAll('.masonry-item');
    
    // Set 'Todos' as active by default
    const allBtn = document.querySelector('[data-filter="all"]');
    if(allBtn) allBtn.classList.add('active');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        // Toggle active classes
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        
        const filterValue = btn.getAttribute('data-filter');
        
        items.forEach(item => {
          if (filterValue === 'all' || item.getAttribute('data-category') === filterValue) {
            item.classList.remove('hidden');
          } else {
            item.classList.add('hidden');
          }
        });
      });
    });

    // Lightbox Logic
    const lightbox = document.getElementById('lightbox');
    const lbClose = document.getElementById('lb-close');
    const lbImg = document.getElementById('lb-img');
    const lbCaption = document.getElementById('lb-caption');

    window.openLightbox = function(src, alt) {
      lbImg.src = src;
      lbCaption.textContent = alt;
      lightbox.classList.add('active');
      document.body.style.overflow = 'hidden'; // prevent scrolling
    };

    lbClose.addEventListener('click', closeLb);
    lightbox.addEventListener('click', (e) => {
      if(e.target === lightbox) closeLb();
    });

    function closeLb() {
      lightbox.classList.remove('active');
      document.body.style.overflow = 'auto';
    }
  });
</script>
