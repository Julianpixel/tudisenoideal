---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/admin/Sidebar.astro';
import SeatingPlanner from '../../components/SeatingPlanner.tsx';
import { db, Guest, Table, eq } from 'astro:db';

let successMsg = '';
let errorMsg   = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action') as string;

  if (action === 'create') {
    const name     = (form.get('name') as string)?.trim();
    const capacity = parseInt(form.get('capacity') as string, 10);

    if (!name || isNaN(capacity) || capacity < 1) {
      errorMsg = 'Por favor ingresa un nombre y capacidad válidos.';
    } else {
      const allTables = await db.select().from(Table);
      const maxOrder  = allTables.reduce((m, t) => Math.max(m, t.order), 0);
      await db.insert(Table).values({ name, capacity, order: maxOrder + 1, type: 'circular' });
      successMsg = `✓ Mesa "${name}" creada con capacidad de ${capacity} personas.`;
    }
  } else if (action === 'delete') {
    const tableId = parseInt(form.get('tableId') as string, 10);
    await db.update(Guest).set({ tableId: null }).where(eq(Guest.tableId, tableId));
    await db.delete(Table).where(eq(Table.id, tableId));
    successMsg = '✓ Mesa eliminada.';
  }
}

const allGuests = await db.select().from(Guest);
const allTables = await db.select().from(Table);
allTables.sort((a, b) => a.order - b.order);
---
<Layout>
  <div class="admin-shell">
    <Sidebar currentPath="/admin/mesas" />

    <main class="admin-main">
      <header class="admin-header">
        <div>
          <p class="header-eyebrow">Panel de Administración</p>
          <h1 class="header-title">Organizador de Mesas</h1>
        </div>
        <a href="/" class="btn btn-forest btn-sm" target="_blank">Ver Sitio →</a>
      </header>

      {successMsg && <div class="alert alert-success">{successMsg}</div>}
      {errorMsg   && <div class="alert alert-error">{errorMsg}</div>}

      <!-- Create table form + delete list -->
      <div class="tables-manage">
        <!-- Create -->
        <div class="manage-card">
          <h3 class="card-title">➕ Crear Nueva Mesa</h3>
          <form method="POST" class="create-form">
            <input type="hidden" name="_action" value="create" />
            <div class="form-row">
              <div class="form-group">
                <label for="tableName">Nombre de la mesa</label>
                <input type="text" id="tableName" name="name" placeholder="Ej: Mesa de Honor" required />
              </div>
              <div class="form-group">
                <label for="tableCapacity">Capacidad (personas)</label>
                <input type="number" id="tableCapacity" name="capacity" min="1" max="30" value="8" required />
              </div>
            </div>
            <button type="submit" class="btn btn-forest">Crear Mesa</button>
          </form>
        </div>

        <!-- Delete -->
        <div class="manage-card">
          <h3 class="card-title">🗑 Eliminar Mesas</h3>
          {allTables.length === 0 && <p class="empty">No hay mesas creadas.</p>}
          <div class="table-list">
            {allTables.map(t => {
              const guests = allGuests.filter(g => g.tableId === t.id);
              const occ    = guests.reduce((s, g) => s + g.partySize, 0);
              return (
                <div class="table-row">
                  <div class="table-info">
                    <span class="table-name">{t.name}</span>
                    <span class="table-cap">{occ}/{t.capacity} personas</span>
                  </div>
                  <form method="POST" style="display:inline">
                    <input type="hidden" name="_action" value="delete" />
                    <input type="hidden" name="tableId" value={t.id} />
                    <button type="submit" class="btn-danger" onclick="return confirm('¿Eliminar esta mesa? Los invitados serán desasignados.')">
                      Eliminar
                    </button>
                  </form>
                </div>
              );
            })}
          </div>
        </div>
      </div>

      <!-- Seating Planner -->
      <div class="planner-card">
        <h3 class="card-title">🪑 Asignación de Mesas (Drag & Drop)</h3>
        <SeatingPlanner client:only="react" initialGuests={allGuests} initialTables={allTables} />
      </div>
    </main>
  </div>
</Layout>

<style>
  .admin-shell { display: flex; min-height: 100vh; background: #f4f5f7; font-family: 'Montserrat', sans-serif; }
  .sidebar { width: 220px; flex-shrink: 0; background: var(--color-forest); display: flex; flex-direction: column; padding: 2rem 0; position: sticky; top: 0; height: 100vh; }
  .sidebar-brand { display: flex; align-items: center; gap: 0.75rem; padding: 0 1.5rem 2rem; border-bottom: 1px solid rgba(255,255,255,0.1); margin-bottom: 1.5rem; }
  .brand-icon { font-size: 1.5rem; color: var(--color-gold); }
  .brand-name { font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; line-height: 1.3; color: rgba(255,255,255,0.9); }
  .sidebar-nav { display: flex; flex-direction: column; gap: 0.25rem; padding: 0 0.75rem; }
  .nav-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 0.85rem; border-radius: 10px; color: rgba(255,255,255,0.65); text-decoration: none; font-size: 0.85rem; font-weight: 500; transition: all 0.25s; }
  .nav-item:hover { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.9); }
  .nav-item.active { background: rgba(201,169,110,0.2); color: var(--color-gold-light); font-weight: 600; }
  .admin-main { flex: 1; padding: 2.5rem 2rem; overflow-y: auto; }
  .admin-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem; }
  .header-eyebrow { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-gold); margin: 0 0 0.25rem; }
  .header-title { font-family: 'Cormorant Garamond', serif; font-size: 2.2rem; font-weight: 400; color: var(--color-forest); margin: 0; }
  .alert { padding: 0.85rem 1.25rem; border-radius: 10px; font-size: 0.85rem; font-weight: 500; margin-bottom: 1.5rem; }
  .alert-success { background: #e6f6ec; color: #1e8449; border: 1px solid #a9dfbf; }
  .alert-error   { background: #fdecea; color: #c0392b; border: 1px solid #f1b4b0; }
  .tables-manage { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem; }
  @media (max-width: 700px) { .tables-manage { grid-template-columns: 1fr; } }
  .manage-card, .planner-card { background: #fff; border-radius: 14px; padding: 2rem; box-shadow: 0 2px 12px rgba(44,74,62,0.06); }
  .planner-card { margin-top: 0; }
  .card-title { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; color: var(--color-forest); margin: 0 0 1.5rem; border-bottom: 1px solid #f0f0f0; padding-bottom: 0.75rem; }
  .create-form { display: flex; flex-direction: column; gap: 1rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  @media (max-width: 500px) { .form-row { grid-template-columns: 1fr; } }
  .form-group { display: flex; flex-direction: column; gap: 0.4rem; }
  label { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #555; }
  input[type="text"], input[type="number"] { padding: 0.8rem 1rem; border: 1.5px solid #e0e0e0; border-radius: 10px; font-family: 'Montserrat', sans-serif; font-size: 0.9rem; width: 100%; box-sizing: border-box; }
  input:focus { outline: none; border-color: var(--color-gold); }
  .btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.85rem 2rem; font-size: 0.82rem; font-family: 'Montserrat', sans-serif; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; border-radius: 50px; cursor: pointer; border: 2px solid; transition: all 0.25s; text-decoration: none; align-self: flex-start; }
  .btn-forest { background: var(--color-forest); color: white; border-color: var(--color-forest); }
  .btn-forest:hover { background: transparent; color: var(--color-forest); }
  .btn-sm { padding: 0.55rem 1.1rem; font-size: 0.72rem; }
  .empty { color: #999; font-style: italic; font-size: 0.9rem; }
  .table-list { display: flex; flex-direction: column; gap: 0.75rem; }
  .table-row { display: flex; align-items: center; justify-content: space-between; padding: 0.85rem 1rem; border: 1px solid #f0f0f0; border-radius: 10px; }
  .table-info { display: flex; flex-direction: column; gap: 0.2rem; }
  .table-name { font-weight: 600; font-size: 0.9rem; color: var(--color-forest); }
  .table-cap { font-size: 0.78rem; color: #888; }
  .btn-danger { background: none; border: 1px solid #f1b4b0; border-radius: 6px; color: #c0392b; font-size: 0.75rem; cursor: pointer; padding: 0.35rem 0.75rem; font-family: 'Montserrat', sans-serif; transition: all 0.2s; }
  .btn-danger:hover { background: #fdecea; }
</style>
